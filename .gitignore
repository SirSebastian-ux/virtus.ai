# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Android / TWA generated files
/.gradle/
/gradle/
/gradlew
/gradlew.bat
/gradle.properties
/settings.gradle
/build.gradle
/manifest-checksum.txt
/store_icon.png
/twa-manifest.json

# Android app build outputs inside Next app folder
/app/build.gradle
/app/build/
/app/src/

# Android signing and release files
/android.keystore
/app-release-bundle.aab
/app-release-signed.apk
/app-release-signed.apk.idsig
/app-release-unsigned-aligned.apk
*.aab
*.apk
*.idsig

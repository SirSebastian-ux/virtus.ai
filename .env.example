# Virtus AI Environment Variables Example
# Copy to .env.local for local development.
# Never commit real secrets.

NEXT_PUBLIC_APP_URL=http://localhost:3000

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

OPENAI_API_KEY=your_openai_api_key
TAVILY_API_KEY=your_tavily_api_key

NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_key
STRIPE_SECRET_KEY=sk_test_your_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

STRIPE_PLUS_MONTHLY_PRICE_ID=price_your_plus_monthly
STRIPE_PLUS_YEARLY_PRICE_ID=price_your_plus_yearly
STRIPE_PREMIUM_MONTHLY_PRICE_ID=price_your_premium_monthly
STRIPE_PREMIUM_YEARLY_PRICE_ID=price_your_premium_yearly

VIRTUS_ADMIN_EMAILS=sebastian@ewellnessolutions.com

# Sentry error monitoring
# DSN is not a password, but keep real project values in Vercel/env settings.
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_ENVIRONMENT=production

# Optional: only needed later for source map upload.
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
